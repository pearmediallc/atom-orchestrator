# Copy to .env and fill in. NEVER commit the real .env file.

# ─── Phase 1 (required to boot) ────────────────────────────
FLASK_SECRET_KEY=replace-with-random-hex-from-secrets-token-hex-32
PORT=5600

# Where the existing ATOM Flask app is reachable. Locally this is the
# default port that ATOM runs on.
ATOM_BASE_URL=http://localhost:5500

# Credentials this orchestrator uses to log into ATOM.
# In production these should be a service-account, NOT a human user.
ATOM_USERNAME=sunny
ATOM_PASSWORD=test123

# ─── Phase 2 (Slack integration) ───────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# ─── Phase 3 (inventory) ───────────────────────────────────
INVENTORY_DB_PATH=./inventory.db

# ─── Phase 4/5 (LLM provider for domain suggestions) ───────
# The OpenAI Python SDK works with any OpenAI-compatible API. Pick one
# provider below and set the three vars accordingly.
#
# Groq (FREE tier, recommended for dev — sign up at console.groq.com):
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=gsk_...
#   OPENAI_MODEL=llama-3.3-70b-versatile
#
# OpenAI (paid — sign up at platform.openai.com):
#   OPENAI_BASE_URL=          (leave empty for OpenAI's default)
#   OPENAI_API_KEY=sk-proj-...
#   OPENAI_MODEL=gpt-4o-mini
#
# Grok / xAI (paid — sign up at console.x.ai):
#   OPENAI_BASE_URL=https://api.x.ai/v1
#   OPENAI_API_KEY=xai-...
#   OPENAI_MODEL=grok-3
#
# Google Gemini (free tier — sign up at aistudio.google.com):
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_API_KEY=AIza...
#   OPENAI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Phase 4 — Namecheap availability check
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=

# ─── Phase 5 (TL approval + manual purchase) ───────────────
# Slack user ID(s) allowed to approve new-domain requests.
# Comma-separated. Find a user's ID: in Slack profile → "More" → Copy member ID.
APPROVER_SLACK_USER_IDS=

# Slack user-ID of whoever buys domains on Namecheap (per TL: manual purchase
# via Utkarsh, not automated). Bot DMs this user when an MDB picks a suggested
# domain. If left empty, bot DMs the requester themselves (useful for self-test).
UTKARSH_SLACK_USER_ID=

# ─── Phase 7 (Mark Done click triggers ATOM setup_domain) ───
# Master switch. When false, Mark Purchased/Deployed clicks update inventory
# only (Phase 2.8 behavior). When true, they ALSO call ATOM to actually
# setup the domain + deploy the lander.
ENABLE_PHASE_7=false

# Source bucket defaults — the Slack modal only collects a lander URL, but
# the workflow needs to know which S3 bucket / folder to copy *from*. These
# fill that gap.
PHASE7_DEFAULT_SOURCE_ACCOUNT=auto-insurance
PHASE7_DEFAULT_SOURCE_BUCKET=
PHASE7_DEFAULT_SOURCE_FOLDERS=

# Optional per-vertical overrides as a JSON map. Example:
#   PHASE7_LANDER_DEFAULTS_JSON={"auto-insurance":{"source_account":"auto-insurance","source_bucket":"pearmedia-default-lander-auto","source_folders":["lander/"]}}
PHASE7_LANDER_DEFAULTS_JSON=
